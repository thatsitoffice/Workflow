---
import Layout from '../layouts/Layout.astro';

const featuredDishes = [
  { name: 'Beetroot & Carrot Halwa', image: '/images/dish-1.jpg' },
  { name: 'Loaded Gyro Fries', image: '/images/dish-2.jpg' },
  { name: 'Green Goddess Soup', image: '/images/dish-3.jpg' },
  { name: 'Baked Feta Pasta', image: '/images/dish-4.jpg' },
  { name: 'Falafels', image: '/images/dish-5.jpg' },
  { name: 'Falafel Bowl', image: '/images/dish-6.jpg' },
];

const galleryCount = 9;
---

<Layout title="Linnavy Restaurant – Be kind to every kind." description="Vollwertig-veganes Restaurant. Erhebe deinen Gaumen, schone die Erde.">
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">be kind to every kind.</h1>
      <p class="hero-subtitle">vollwertig-veganes Restaurant. Erhebe deinen Gaumen, schone die Erde.</p>
      <a href="/menu/" class="btn hero-cta">See Menu</a>
    </div>
    <div class="hero-bg" aria-hidden="true"></div>
  </section>

  <section class="dishes section">
    <h2 class="section-title">Highlights</h2>
    <p class="section-subtitle">Unsere beliebtesten Gerichte – rein pflanzlich und voller Geschmack.</p>
    <div class="dishes-grid">
      {featuredDishes.map((dish, i) => (
        <article class="dish-card">
          <div class="dish-image">
            <img src={`https://placehold.co/400x300/1a1a18/c9a227?text=${encodeURIComponent(dish.name)}`} alt={dish.name} width="400" height="300" />
          </div>
          <h3 class="dish-name">{dish.name}</h3>
        </article>
      ))}
    </div>
  </section>

  <section class="eat-sip section">
    <div class="eat-sip-inner">
      <a href="/menu/#eat" class="eat-sip-card">
        <span class="eat-sip-icon" aria-hidden="true">eat</span>
        <span class="eat-sip-label">Essen</span>
      </a>
      <a href="/menu/#drinks" class="eat-sip-card">
        <span class="eat-sip-icon" aria-hidden="true">sip</span>
        <span class="eat-sip-label">Trinken</span>
      </a>
    </div>
  </section>

  <section class="tagline section">
    <h2 class="section-title">deliciously bold in every bite.</h2>
    <a href="/menu/" class="btn">See Menu</a>
  </section>

  <section class="gallery section">
    <h2 class="section-title">Galerie</h2>
    <div class="gallery-grid">
      {Array.from({ length: galleryCount }, (_, i) => (
        <div class="gallery-item">
          <img src={`https://placehold.co/400x400/1a1a18/a39e92?text=Gallery+${i + 1}`} alt={`Galerie ${i + 1}`} width="400" height="400" loading="lazy" />
        </div>
      ))}
    </div>
    <p class="gallery-more">
      <a href="/contact/">Mehr auf Anfrage</a>
    </p>
  </section>

  <section class="cta section" id="order">
    <h2 class="section-title">Jetzt bestellen</h2>
    <p class="section-subtitle">Reservierung oder Abholung – wir freuen uns auf dich.</p>
    <a href="/contact/" class="btn">Contact & Order</a>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--color-surface) 0%, var(--color-bg) 50%);
    z-index: -1;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a227' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 600;
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }
  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .hero-cta {
    margin-top: 0.5rem;
  }

  .dishes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .dish-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .dish-image {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .dish-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dish-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    padding: 1rem;
  }

  .eat-sip {
    background: var(--color-accent-soft);
  }
  .eat-sip-inner {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .eat-sip-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem 3rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 2px solid var(--color-accent);
    transition: transform 0.2s;
  }
  .eat-sip-card:hover {
    transform: translateY(-4px);
  }
  .eat-sip-icon {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .eat-sip-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .tagline {
    text-align: center;
  }
  .tagline .btn {
    margin-top: 0.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .gallery-item {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--radius);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gallery-more {
    text-align: center;
    margin-top: 1.5rem;
    color: var(--color-text-muted);
  }
  .gallery-more a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cta {
    text-align: center;
    padding-bottom: 5rem;
  }
</style>
