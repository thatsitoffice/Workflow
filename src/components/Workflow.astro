function getIcon(iconName: string): string {
  const icons: Record<string, string> = {
    concept: '<path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z" />',
    design: '<path d="M8.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L2.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z" /><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z" />',
    implementation: '<path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z" /><path d="M9.854 8.146a.5.5 0 0 0-.708.708l.646.647-.646.647a.5.5 0 0 0 .708.708l.647-.646.647.646a.5.5 0 0 0 .708-.708l-.646-.647.646-.647a.5.5 0 0 0-.708-.708l-.647.646-.647-.646z" />',
    feedback: '<path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" /><path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94" />',
    launch: '<path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" /><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />',
  };
  return icons[iconName] || icons.concept;
}

---

<section class="workflow" id="workflow">
  <div class="container">
    <h2>Unser Webseiten-Workflow</h2>
    <p class="subtitle">
      Von der ersten Kontaktaufnahme bis zum erfolgreichen Launch – wir begleiten Sie durch einen strukturierten Prozess, der Transparenz, Effizienz und exzellente Ergebnisse garantiert.
    </p>

    <!-- Onboarding Process -->
    <div class="onboarding-timeline">
      <h3>Der Onboarding-Prozess</h3>
      <div class="timeline">
        {onboardingPhases.map((phase) => (
          <div class="timeline-item">
            <div class="timeline-number">{phase.number}</div>
            <div class="timeline-content">
              <h4>{phase.title}</h4>
              <p>{phase.description}</p>
              <ul>
                {phase.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Project Phases -->
    <div class="project-phases">
      <h3>Die Projektphasen</h3>
      <div class="phases-flow">
        {projectPhases.map((phase) => (
          <div class="phase-step">
            <div class="phase-icon">
              <svg viewBox="0 0 16 16" aria-hidden="true" set:html={getIcon(phase.icon)} />
            </div>
            <h4>{phase.name}</h4>
            <p>{phase.description}</p>
          </div>
        ))}
      </div>

      <div class="process-details">
        {processDetails.map((detail) => (
          <div class="process-card">
            <h4>{detail.title}</h4>
            <ul>
              {detail.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
