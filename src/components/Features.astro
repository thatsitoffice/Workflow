<section class="features" id="services">
  <div class="container">
    <h2>Unsere Webentwicklung Services</h2>
    <p class="subtitle">
      Entdecken Sie, wie wir Ihnen dabei helfen können, Ihre Online-Präsenz zu optimieren und mehr Kunden zu gewinnen.
    </p>
    <div class="feature-grid">
      {features.map((feature) => (
        <div class="feature">
          <div set:html={feature.icon}></div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
