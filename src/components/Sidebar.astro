---
const navItems = [
  { href: '#home', label: 'Home' },
  { href: '#services', label: 'Services' },
  { href: '#about', label: 'About' },
  { href: '#workflow', label: 'Workflow' },
];
---

<aside class="sidebar">
  <img src="/images/logo_white.png" alt="That's it Marketing Logo" class="logo" />
  <nav class="nav">
    {navItems.map((item) => (
      <a href={item.href} class={item.href === '#home' ? 'active' : ''}>
        {item.label}
      </a>
    ))}
  </nav>
  <button class="cookie-btn desktop-cookie-btn-text">Cookie-Einstellungen</button>
</aside>
<button class="mobile-cookie-btn cookie-btn-icon" aria-label="Cookie-Einstellungen">
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10z"/>
  </svg>
</button>
<button class="desktop-cookie-btn-icon cookie-btn-icon" aria-label="Cookie-Einstellungen">
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10z"/>
  </svg>
</button>